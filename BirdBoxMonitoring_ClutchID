// Calculated expression for the Bird Box Monitoring related table
var box = $feature.box_id;
var trigger = $feature.new_clutch;

// 1. Get the history for this specific box, ordered by date (newest first)
var box_history = OrderBy(Filter($layer, "box_id = '" + box + "'"), "cdate DESC");
var last_rec = First(box_history);

// 2. Scenario A: A new clutch is starting (Trigger is explicitly 'Yes')
if (trigger == 'Yes') {
    // Filter history to find existing unique clutch IDs
    var valid_history = Filter(box_history, "clutch_id IS NOT NULL");
    var unique_clutches = Distinct(valid_history, "clutch_id");
    
    var valid_clutch_count = 0;
    for (var item in unique_clutches) {
        if (!IsEmpty(item.clutch_id) && item.clutch_id != "") {
            valid_clutch_count++;
        }
    }
    
    var next_num = valid_clutch_count + 1;
    return box + "_clutch" + Text(next_num, "00");
} 

// 3. Scenario B: Carrying forward (Trigger is 'No', 'Unsure', or Null/Empty)
else {
    // If a previous record exists, carry over its clutch_id
    if (!IsEmpty(last_rec) && !IsEmpty(last_rec.clutch_id)) {
        return last_rec.clutch_id;
    } 
    
    // Otherwise, if there's no history or the last record was also null, return null
    return null;
}
